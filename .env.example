# ================================================
# wh-op-platform 环境变量配置
# ================================================
# 使用说明：复制本文件为 .env，然后修改实际值
#   cp .env.example .env
# ================================================

# -------------------- MySQL 数据库连接 --------------------
# MySQL 主机地址
MYSQL_HOST=10.126.50.199
# MySQL 端口
MYSQL_PORT=3306
# 数据库名（Backend 使用 MYSQL_DB，Analytics 使用 MYSQL_DATABASE）
MYSQL_DB=wh_op_baseline
MYSQL_DATABASE=wh_op_baseline
# 数据库用户名（请填写实际用户名）
MYSQL_USER=your_username
# 数据库密码（请填写实际密码）
MYSQL_PASSWORD=your_password

# -------------------- 服务配置 --------------------
# Python 分析服务地址（Backend 调用，Docker 内部通信使用 http://analytics:8000）
ANALYTICS_BASE_URL=http://analytics:8000
# SQLite 预计算结果存储路径
SQLITE_PATH=/data/results.db
